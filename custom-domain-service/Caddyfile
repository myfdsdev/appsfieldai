{
	on_demand_tls {
		ask http://localhost:4000/api/ask
		interval 2m
		burst 5
	}
}

# This service's own fixed hostname (admin API + public lookup endpoint).
# Gets a normal automatic cert like any static Caddy site — explicit site
# blocks are NOT subject to the on-demand "ask" gate below.
{$PUBLIC_SERVICE_HOST} {
	reverse_proxy localhost:4000
}

# Catch-all for arbitrary customer-owned domains CNAME'd/A'd at this server.
# Cert issuance for these is gated by the "ask" endpoint above.
:443 {
	tls {
		on_demand
	}
	reverse_proxy localhost:4000
}

:80 {
	redir https://{host}{uri} permanent
}
