# Node app port (internal only — Caddy is the public entry point on 80/443)
PORT=4000
NODE_ENV=production

# Bearer token the Base44 frontend (DomainManager.jsx) must send for admin API calls
VERIFICATION_SECRET=change-me-to-a-long-random-secret

# Where verified custom-domain traffic gets reverse-proxied to (the live Base44 app).
# Must be a normal HTTPS origin the SNI/Host header actually matches — do not point
# this at base44.onrender.com directly, Cloudflare blocks mismatched Host/SNI requests.
UPSTREAM_ORIGIN=https://app.appsfieldai.com

# Base44 app host used to call public functions (getMarketplacePublic) via direct HTTP.
BASE44_FUNCTIONS_ORIGIN=https://share-saas-hq.base44.app

# This service's own public hostname — the CNAME target shown in DNS
# instructions for subdomain custom domains (e.g. deals.brand.com).
PUBLIC_SERVICE_HOST=connect.appsfieldai.com

# This service's own public static IP — the A-record target for apex/root
# custom domains (e.g. brand.com). Set once deployed to a real host.
PUBLIC_SERVICE_IP=203.0.113.10

# MongoDB connection for the domain-mappings collection
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=appsfieldai
MONGODB_COLLECTION=domain_mappings

# Optional: lock CORS to the Base44 frontend origin instead of "*"
# CORS_ORIGIN=https://share-saas-hq.base44.app
