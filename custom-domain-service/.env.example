# Node app port. Render provides PORT automatically; keep 4000 for local dev.
PORT=4000
NODE_ENV=production

# Bearer token the Base44 frontend (DomainManager.jsx) must send for admin API calls
VERIFICATION_SECRET=change-me-to-a-long-random-secret

# Where custom-domain traffic gets reverse-proxied to (the live Base44 app).
UPSTREAM_ORIGIN=https://app.appsfieldai.com

# Base44 app host used to call public functions (getMarketplacePublic) via direct HTTP.
BASE44_FUNCTIONS_ORIGIN=https://share-saas-hq.base44.app

# Render API — used to add/verify/remove customer custom domains on this service.
# RENDER_API_KEY: Render dashboard → Account Settings → API Keys.
# RENDER_SERVICE_ID: the srv-xxxx id of THIS service (from its dashboard URL).
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# This service's own onrender.com host — the CNAME target shown to customers for
# subdomain custom domains (e.g. deals.brand.com). Set after the first deploy.
PUBLIC_SERVICE_HOST=custom-domain-service-xxxx.onrender.com

# Render's shared A-record IP for apex/root custom domains (e.g. brand.com).
PUBLIC_SERVICE_IP=216.24.57.1

# MongoDB connection for the domain-mappings collection
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=appsfieldai
MONGODB_COLLECTION=domain_mappings

# Optional: lock CORS to the Base44 frontend origin instead of "*"
# CORS_ORIGIN=https://share-saas-hq.base44.app
