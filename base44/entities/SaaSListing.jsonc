{
  "name": "SaaSListing",
  "type": "object",
  "properties": {
    "marketplaceId": {
      "type": "string",
      "description": "The ID of the marketplace this listing belongs to"
    },
    "vendorId": {
      "type": "string",
      "description": "The ID of the approved vendor who listed this"
    },
    "ownerId": {
      "type": "string",
      "description": "The user ID of the original owner/seller"
    },
    "softwareName": {
      "type": "string",
      "description": "Software name / title"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly unique slug"
    },
    "logo": {
      "type": "string",
      "description": "Logo image URL"
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Screenshot image URLs"
    },
    "demoVideoUrl": {
      "type": "string",
      "description": "Demo video URL"
    },
    "shortDescription": {
      "type": "string",
      "description": "Short description / tagline"
    },
    "fullDescription": {
      "type": "string",
      "description": "Full detailed description"
    },
    "category": {
      "type": "string",
      "description": "Category name (e.g. CRM, AI & ML)"
    },
    "categoryId": {
      "type": "string",
      "description": "Linked SoftwareCategory ID"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of key features"
    },
    "usageLimits": {
      "type": "string",
      "description": "Plan limits included for the buyer (e.g. 5 users, 10k credits/mo, 3 seats)"
    },
    "supportInfo": {
      "type": "string",
      "description": "Support offered to the buyer (channels, hours, response time)"
    },
    "refundPolicy": {
      "type": "string",
      "description": "Refund policy shown clearly on the product page"
    },
    "redemptionInstructions": {
      "type": "string",
      "description": "How the buyer redeems / activates access after purchase"
    },
    "pricingType": {
      "type": "string",
      "enum": [
        "free",
        "paid",
        "subscription",
        "lifetime_deal",
        "custom_quote"
      ],
      "default": "paid",
      "description": "Pricing model"
    },
    "price": {
      "type": "number",
      "description": "Single buy / full price"
    },
    "discountPrice": {
      "type": "number",
      "description": "Discounted deal price"
    },
    "dealType": {
      "type": "string",
      "enum": [
        "group_deal",
        "single_purchase",
        "both"
      ],
      "default": "group_deal",
      "description": "Deal offering type"
    },
    "sharePrice": {
      "type": "number",
      "description": "Price per individual spot/share"
    },
    "totalShares": {
      "type": "number",
      "description": "Total number of spots/shares"
    },
    "soldShares": {
      "type": "number",
      "default": 0,
      "description": "Number of spots/shares already sold"
    },
    "noDayLimit": {
      "type": "boolean",
      "default": false,
      "description": "Whether the deal has no time limit"
    },
    "dealDurationDays": {
      "type": "number",
      "description": "Duration of the deal in days"
    },
    "dealStartDate": {
      "type": "string",
      "format": "date-time",
      "description": "Deal start date"
    },
    "dealEndDate": {
      "type": "string",
      "format": "date-time",
      "description": "Deal end date"
    },
    "dealStatus": {
      "type": "string",
      "enum": [
        "upcoming",
        "live",
        "funded",
        "completed",
        "expired"
      ],
      "default": "live",
      "description": "Deal lifecycle status"
    },
    "salesPaused": {
      "type": "boolean",
      "default": false,
      "description": "When true, sales/checkout for this product are paused immediately"
    },
    "monthlyRevenue": {
      "type": "number",
      "description": "Monthly revenue in dollars"
    },
    "monthlyExpenses": {
      "type": "number",
      "default": 0,
      "description": "Monthly expenses in dollars"
    },
    "growthRate": {
      "type": "number",
      "default": 0,
      "description": "Growth rate percentage"
    },
    "rating": {
      "type": "number",
      "default": 5,
      "description": "Rating out of 5"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "approved",
        "rejected",
        "suspended",
        "active",
        "auction",
        "sold"
      ],
      "default": "pending",
      "description": "Listing status"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the software is featured"
    },
    "isBestSeller": {
      "type": "boolean",
      "default": false,
      "description": "Whether this listing is marked as a best seller"
    },
    "isLifetimeDeal": {
      "type": "boolean",
      "default": false,
      "description": "Whether this listing is a lifetime deal"
    },
    "auctionEndsAt": {
      "type": "string",
      "format": "date-time",
      "description": "Auction end date-time"
    },
    "riskScore": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "default": 5
    },
    "aiScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 75
    },
    "sellerName": {
      "type": "string",
      "description": "Name of the seller"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of tags"
    },
    "imageGradient": {
      "type": "string",
      "description": "CSS gradient for card header"
    },
    "customButton": {
      "type": "object",
      "description": "Optional custom action button that replaces the default Buy button on the store \u2014 redirects to any URL instead of starting checkout",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, the product's primary button redirects to the custom URL instead of starting checkout"
        },
        "label": {
          "type": "string",
          "description": "Custom button label (e.g. Check Our Offer, Learn More). Falls back to 'Learn More' when empty"
        },
        "url": {
          "type": "string",
          "description": "The URL the button opens (external site or another page)"
        },
        "openInNewTab": {
          "type": "boolean",
          "default": true,
          "description": "Whether to open the custom URL in a new tab"
        }
      }
    },
    "delivery": {
      "type": "object",
      "description": "Default product delivery / access info given to buyers after purchase",
      "properties": {
        "accessUrl": {
          "type": "string",
          "description": "Product access URL"
        },
        "instructions": {
          "type": "string",
          "description": "Default access instructions, license details, or login info"
        }
      }
    },
    "revenueProofFiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of revenue proof documents"
    },
    "affiliateEnabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether this product is open for affiliates to promote and earn commission"
    },
    "affiliateCommissionRate": {
      "type": "number",
      "default": 30,
      "description": "Commission percentage affiliates earn on each sale of this product"
    },
    "affiliateCommissionRule": {
      "type": "string",
      "description": "Notes/rules for affiliates (e.g. paid after refund window, minimum payout, allowed channels)"
    },
    "promotionKit": {
      "type": "object",
      "description": "Marketing assets provided to approved affiliates",
      "properties": {
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Promotional image URLs (banners, creatives)"
        },
        "videos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Promotional video URLs"
        },
        "emailSwipes": {
          "type": "array",
          "description": "Ready-to-send email swipe copy",
          "items": {
            "type": "object",
            "properties": {
              "subject": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            }
          }
        },
        "llmDescription": {
          "type": "string",
          "description": "Rich product description for affiliates to feed an LLM to write emails, ads and copy"
        }
      }
    }
  },
  "required": [
    "softwareName"
  ]
}