{
  "name": "Affiliate",
  "type": "object",
  "properties": {
    "marketplaceId": {
      "type": "string",
      "description": "The marketplace this affiliate belongs to"
    },
    "storeCustomerId": {
      "type": "string",
      "description": "The StoreCustomer account this affiliate is linked to"
    },
    "fullName": {
      "type": "string",
      "description": "Affiliate full name (copied from the store customer)"
    },
    "email": {
      "type": "string",
      "description": "Affiliate email"
    },
    "refCode": {
      "type": "string",
      "description": "Unique referral code used in ?ref= links for this affiliate in this store"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended"
      ],
      "default": "active",
      "description": "Overall affiliate account status in this store"
    },
    "commissionRate": {
      "type": "number",
      "description": "Optional affiliate-wide commission override (percent). Product/application rate takes precedence when set."
    },
    "holdDays": {
      "type": "number",
      "description": "Performance-based hold window override (days) for this affiliate. Falls back to the store's affiliateSettings.holdDays when empty. Owner lowers it for trusted, low-refund affiliates."
    },
    "payoutMethod": {
      "type": "string",
      "description": "Affiliate's preferred payout method (e.g. PayPal, Bank Wire)"
    },
    "payoutDetails": {
      "type": "string",
      "description": "Affiliate's payout account details (PayPal email, bank/wire info)"
    },
    "totalEarned": {
      "type": "number",
      "default": 0,
      "description": "Lifetime cleared commission earned"
    },
    "totalPending": {
      "type": "number",
      "default": 0,
      "description": "Commission currently on hold (within refund window)"
    },
    "totalPaid": {
      "type": "number",
      "default": 0,
      "description": "Lifetime commission actually paid out to the affiliate"
    }
  },
  "required": [
    "marketplaceId",
    "storeCustomerId",
    "refCode"
  ]
}