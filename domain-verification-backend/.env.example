# Server
PORT=3000
NODE_ENV=development

# Bearer token the Base44 frontend must send to POST /api/verify-custom-domain
VERIFICATION_SECRET=your-secret-token-for-bearer-auth

# The real host Base44 serves the app on — every custom domain must CNAME here.
CNAME_TARGET=base44.onrender.com

# Fallback platform domain if none is configured in AppConfig (key: "main").
PLATFORM_DOMAIN=yourdomain.com

# Base44 REST API access
BASE44_API_KEY=
BASE44_API_URL=https://api.base44.com

# Optional: lock CORS to the Base44 frontend origin instead of "*"
# CORS_ORIGIN=https://share-saas-hq.base44.app
